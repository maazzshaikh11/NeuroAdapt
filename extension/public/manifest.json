{
  "manifest_version": 3,
  "name": "NeuroAdapt",
  "version": "1.0",
  "description": "AI-powered web accessibility for Dyslexia, ADHD, and more.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/content.js"
      ]
    }
  ],
  "background": {
    "service_worker": "src/background/service_worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "fonts/OpenDyslexic-Regular.woff2",
        "logo.jpeg"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}