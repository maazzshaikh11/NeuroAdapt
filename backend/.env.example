# ── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ───────────────────────────────────────────
# Get from MongoDB Atlas → Connect → Drivers
MONGODB_URI=

# ── Auth ───────────────────────────────────────────────
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Groq AI ────────────────────────────────────────────
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEY_6=

GROQ_MODEL=llama-3.3-70b-versatile

# ── Rate Limiting ──────────────────────────────────────
# Simplify API (per IP, 60s window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20
GUEST_DAILY_LIMIT=3

# Auth endpoints (login, register, etc.) — per IP, 15-minute window
# Development default: 100 requests. Production default: 5 requests.
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=100

# ── Cache ──────────────────────────────────────────────
CACHE_TTL_DAYS=30

# ── CORS ───────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=chrome-extension://YOUR_EXTENSION_ID,http://localhost:3000

# ── Logging ────────────────────────────────────────────
LOG_LEVEL=info